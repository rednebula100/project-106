---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { timeline } from '../../data/timeline.js';

const eras = [...new Set(timeline.map((e) => e.era))];
const grouped = eras.map((era) => ({
  era,
  events: timeline.filter((e) => e.era === era),
}));
---
<BaseLayout title="사건 연표">
  <div class="page-header">
    <h1 class="page-title">// 사건 연표</h1>
    <p class="page-subtitle">총 {timeline.length}건 — 시간순 정렬</p>
  </div>

  <div class="timeline">
    {grouped.map((group) => (
      <div class="era-group">
        <div class="era-marker">
          <span class="era-label">{group.era}</span>
          <div class="era-line" />
        </div>
        <ul class="event-list">
          {group.events.map((e) => (
            <li class="event-item">
              <span class="event-dot" />
              <span class="event-text">{e.event}</span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .page-title {
    font-size: 1.1rem;
    letter-spacing: 0.15em;
    color: var(--accent-blue);
    margin-bottom: 0.3rem;
  }

  .page-subtitle {
    font-size: 0.75rem;
    color: var(--text-dim);
    letter-spacing: 0.05em;
  }

  .timeline {
    max-width: 600px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .era-group {
    display: flex;
    flex-direction: column;
  }

  .era-marker {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
    padding-top: 1.5rem;
  }

  .era-label {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    color: var(--accent-blue);
    text-transform: uppercase;
    white-space: nowrap;
  }

  .era-line {
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .event-list {
    list-style: none;
    padding-left: 1rem;
    border-left: 1px solid var(--border);
    margin-bottom: 0.25rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .event-item {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.45rem 0 0.45rem 0;
    position: relative;
  }

  .event-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--border);
    flex-shrink: 0;
    margin-top: 0.1rem;
    position: relative;
    left: -1.33rem;
    margin-right: -0.58rem;
  }

  .event-text {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.6;
  }
</style>
