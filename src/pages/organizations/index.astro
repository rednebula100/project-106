---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { organizations } from '../../data/organizations.js';

const statusColor = {
  '활동 중': '#ffaa4a',
  '해산': '#ff4a4a',
};
---
<BaseLayout title="조직 데이터베이스">
  <div class="page-header">
    <h1 class="page-title">// 조직 데이터베이스</h1>
    <p class="page-subtitle">등록 조직 총 {organizations.length}건</p>
  </div>

  <div class="card-grid">
    {organizations.map((org) => (
      <a href={`${import.meta.env.BASE_URL}organizations/${org.slug}`} class="card">
        <div class="card-top">
          <span class="card-name">{org.name}</span>
          <span
            class="card-status"
            style={`color: ${statusColor[org.status] ?? '#c8c8c8'}`}
          >
            {org.status}
          </span>
        </div>
        <div class="card-type">{org.type}</div>
        <p class="card-desc">{org.description}</p>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .page-title {
    font-size: 1.1rem;
    letter-spacing: 0.15em;
    color: var(--accent-blue);
    margin-bottom: 0.3rem;
  }

  .page-subtitle {
    font-size: 0.75rem;
    color: var(--text-dim);
    letter-spacing: 0.05em;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .card {
    display: block;
    border: 1px solid var(--border);
    padding: 1.25rem;
    background: var(--bg-surface);
    color: var(--text);
    transition: border-color 0.15s;
  }

  .card:hover {
    border-color: var(--accent-blue);
    text-decoration: none;
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.3rem;
  }

  .card-name {
    font-size: 1rem;
    color: var(--text-bright);
    letter-spacing: 0.1em;
  }

  .card-status {
    font-size: 0.7rem;
    letter-spacing: 0.08em;
  }

  .card-type {
    font-size: 0.7rem;
    color: var(--text-dim);
    letter-spacing: 0.06em;
    margin-bottom: 0.75rem;
  }

  .card-desc {
    font-size: 0.76rem;
    color: var(--text-dim);
    line-height: 1.6;
  }
</style>
