---
import BaseLayout from '../layouts/BaseLayout.astro';

const sections = [
  {
    title: '캐릭터',
    desc: '등록된 인원 데이터베이스. 주인공, 대립자, 배면세계 거주자 및 기타 인원.',
    href: '/characters',
  },
  {
    title: '조직',
    desc: 'EGO 및 VOID COVENANT의 조직 구조, 위계, 운영 기록.',
    href: '/organizations',
  },
  {
    title: '세계관',
    desc: '우주 구조, 심연, 배면세계, 현무고등학교 환경 분석 자료.',
    href: '/world',
  },
  {
    title: '프로젝트 기록',
    desc: 'PROJECT 106 진행 현황 및 과거 실패 기록 열람.',
    href: '/projects',
  },
  {
    title: '연표',
    desc: '인가된 사건 발생 순서 및 타임라인 정렬 데이터.',
    href: '/timeline',
  },
  {
    title: '초물질',
    desc: '초물질 분류, 특성, 위험도 평가 및 상호작용 연구 자료.',
    href: '/substances',
  },
];
---
<BaseLayout title="메인">
  <div class="page-header">
    <h1 class="page-title">[ PROJECT 106 ]</h1>
    <p class="page-subtitle">EGO 내부 열람 시스템 — 인가된 접근만 허용</p>
  </div>

  <div class="grid">
    {sections.map((s) => (
      <a href={s.href} class="card">
        <div class="card-title">{s.title}</div>
        <div class="card-desc">{s.desc}</div>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .page-title {
    font-size: 1.4rem;
    letter-spacing: 0.2em;
    color: var(--accent-blue);
    margin-bottom: 0.5rem;
  }

  .page-subtitle {
    font-size: 0.82rem;
    color: var(--text-dim);
    letter-spacing: 0.05em;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }

  .card {
    display: block;
    border: 1px solid var(--border);
    padding: 1.25rem;
    background: var(--bg-surface);
    color: var(--text);
    transition: border-color 0.15s;
  }

  .card:hover {
    border-color: var(--accent-blue);
    text-decoration: none;
  }

  .card-title {
    font-size: 0.95rem;
    letter-spacing: 0.1em;
    color: var(--text-bright);
    margin-bottom: 0.5rem;
  }

  .card-desc {
    font-size: 0.76rem;
    color: var(--text-dim);
    line-height: 1.55;
  }
</style>
