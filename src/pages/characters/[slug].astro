---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { characters } from '../../data/characters.js';

export function getStaticPaths() {
  return characters.map((c) => ({
    params: { slug: c.slug },
    props: { character: c },
  }));
}

const { character: c } = Astro.props;

const statusColor = {
  '생존': '#4a9eff',
  '소멸': '#ff4a4a',
  '활동 중': '#ffaa4a',
};

const fields = [
  { label: '이름',   value: c.name },
  { label: '나이',   value: c.age },
  { label: '소속',   value: c.school },
  { label: '능력',   value: c.ability },
  { label: '코드명', value: c.codename },
  { label: '분류',   value: c.category },
];
---
<BaseLayout title={c.name}>
  <div class="doc">
    <div class="doc-header">
      <div class="doc-codename glitch" data-text={c.codename}>{c.codename}</div>
      <span
        class="doc-status"
        style={`color: ${statusColor[c.status] ?? '#c8c8c8'}; border-color: ${statusColor[c.status] ?? '#2a2a2a'}`}
      >
        {c.status}
      </span>
    </div>

    <div class="doc-subtitle">인원 데이터 열람 — EGO 내부 문서</div>

    <table class="doc-table">
      <tbody>
        {fields.map((f) => (
          <tr>
            <th>{f.label}</th>
            <td>{f.value}</td>
          </tr>
        ))}
      </tbody>
    </table>

    {c.image && (
      <div class="doc-image">
        <img src={`${import.meta.env.BASE_URL}images/${c.image}`} alt={c.name} />
      </div>
    )}

    {c.evolutionStages && (
      <div class="evo-section">
        <div class="note-label">[ 진화 단계 ]</div>
        <div class="evo-grid">
          {c.evolutionStages.map((s) => (
            <div class="evo-card">
              <div class="evo-stage">STAGE {s.stage}</div>
              {s.image
                ? <img src={`${import.meta.env.BASE_URL}images/${s.image}`} alt={s.name} />
                : <div class="evo-no-image">—</div>
              }
              <div class="evo-name">{s.name}</div>
            </div>
          ))}
        </div>
      </div>
    )}

    <div class="doc-note">
      <div class="note-label">[ 비고 ]</div>
      <p class="note-body">{c.description}</p>
    </div>

    {c.notes && c.notes.length > 0 && (
      <div class="doc-note">
        <div class="note-label">[ 추가 정보 ]</div>
        <ul class="note-list">
          {c.notes.map((n) => <li>{n}</li>)}
        </ul>
      </div>
    )}

    <div class="back-link">
      <a href={`${import.meta.env.BASE_URL}characters`}>← 목록으로 돌아가기</a>
    </div>
  </div>
</BaseLayout>

<style>
  .doc {
    max-width: 620px;
  }

  .doc-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.3rem;
  }

  .doc-codename {
    font-size: 1.3rem;
    letter-spacing: 0.2em;
    color: var(--text-bright);
  }

  .doc-status {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    border: 1px solid;
    padding: 0.2rem 0.6rem;
  }

  .doc-subtitle {
    font-size: 0.72rem;
    color: var(--text-dim);
    letter-spacing: 0.06em;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .doc-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
  }

  .doc-table th,
  .doc-table td {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border);
    font-size: 0.82rem;
    text-align: left;
    font-weight: normal;
  }

  .doc-table th {
    width: 90px;
    color: var(--text-dim);
    letter-spacing: 0.06em;
    background: var(--bg-secondary);
    white-space: nowrap;
  }

  .doc-table td {
    color: var(--text);
  }

  .doc-note {
    border: 1px solid var(--border);
    padding: 1rem;
    background: var(--bg-surface);
    margin-bottom: 1.5rem;
  }

  .note-label {
    font-size: 0.72rem;
    color: var(--text-dim);
    letter-spacing: 0.1em;
    margin-bottom: 0.6rem;
  }

  .note-body {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.7;
  }

  .back-link {
    font-size: 0.78rem;
  }

  .back-link a {
    color: var(--text-dim);
    transition: color 0.15s;
  }

  .back-link a:hover {
    color: var(--accent-blue);
    text-decoration: none;
  }

  .doc-image {
    margin-bottom: 1.5rem;
    border: 1px solid var(--border);
  }

  .doc-image img {
    width: 100%;
    display: block;
    filter: grayscale(20%);
  }

  .evo-section {
    margin-bottom: 1.5rem;
    border: 1px solid var(--border);
    padding: 1rem;
    background: var(--bg-surface);
  }

  .evo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: 0.6rem;
    margin-top: 0.6rem;
  }

  .evo-card {
    border: 1px solid var(--border);
    background: var(--bg-secondary);
    text-align: center;
    overflow: hidden;
  }

  .evo-stage {
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    padding: 0.3rem 0;
    border-bottom: 1px solid var(--border);
  }

  .evo-card img {
    width: 100%;
    display: block;
    filter: grayscale(20%);
  }

  .evo-no-image {
    height: 100px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-dim);
    font-size: 0.9rem;
    opacity: 0.4;
  }

  .evo-name {
    font-size: 0.7rem;
    color: var(--text);
    padding: 0.35rem 0.25rem;
    letter-spacing: 0.04em;
    border-top: 1px solid var(--border);
  }

  .note-list {
    margin: 0;
    padding-left: 1.2rem;
    list-style: none;
  }

  .note-list li {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.7;
    padding-left: 0.5rem;
    margin-bottom: 0.4rem;
  }

  .note-list li::before {
    content: "—";
    color: var(--text-dim);
    margin-right: 0.4rem;
    margin-left: -1.2rem;
  }
</style>
