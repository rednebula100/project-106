---
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const { title = '메인' } = Astro.props;
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <title>{title} — PROJECT 106</title>
    <script is:inline type="importmap">{"imports":{"three":"https://cdn.jsdelivr.net/npm/three@0.170.0/build/three.module.js","three/addons/":"https://cdn.jsdelivr.net/npm/three@0.170.0/examples/jsm/"}}</script>
  </head>
  <body>
    <div class="page-ui">
      <Header />
      <div class="layout">
        <Sidebar />
        <main class="main">
          <slot />
        </main>
      </div>
      <Footer />
    </div>
    <script is:inline>
      (function () {
        var h1 = document.querySelector('main h1');
        if (!h1) return;
        var text = h1.textContent || '';
        h1.textContent = '';
        var cursor = document.createElement('span');
        cursor.className = 'type-cursor';
        cursor.textContent = '|';
        h1.appendChild(cursor);
        var i = 0;
        function tick() {
          if (i < text.length) {
            h1.insertBefore(document.createTextNode(text[i]), cursor);
            i++;
            setTimeout(tick, 50);
          } else {
            setTimeout(function () { cursor.remove(); }, 1000);
          }
        }
        tick();
      })();
    </script>
  </body>
</html>

<style>
  .page-ui {
    position: relative;
    z-index: 1;
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  .layout {
    flex: 1;
    display: flex;
    min-height: 0;
  }

  .main {
    flex: 1;
    padding: 2rem;
    overflow-y: auto;
  }
</style>
