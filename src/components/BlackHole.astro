---
---
<canvas id="bh-canvas"></canvas>

<style>
  #bh-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    opacity: 0.85;
    pointer-events: none;
  }
</style>

<script>
import * as THREE from 'three';

(function () {
  const canvas = document.getElementById('bh-canvas');
  if (!canvas) return;

  const isMobile = window.innerWidth < 768;
  const dpr = isMobile ? 0.5 : Math.min(window.devicePixelRatio, 1.5);

  const renderer = new THREE.WebGLRenderer({ canvas, antialias: !isMobile, alpha: true });
  renderer.setPixelRatio(dpr);
  renderer.setSize(window.innerWidth, window.innerHeight);

  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(50, window.innerWidth / window.innerHeight, 0.1, 1000);
  camera.position.set(0, 18, 58);
  camera.lookAt(0, 0, 0);

  // ── Stars ──
  const STAR_COUNT = 1400;
  const starPos = new Float32Array(STAR_COUNT * 3);
  for (let i = 0; i < STAR_COUNT; i++) {
    const theta = Math.random() * Math.PI * 2;
    const phi = Math.acos(2 * Math.random() - 1);
    const r = 130 + Math.random() * 70;
    starPos[i * 3]     = r * Math.sin(phi) * Math.cos(theta);
    starPos[i * 3 + 1] = r * Math.sin(phi) * Math.sin(theta);
    starPos[i * 3 + 2] = r * Math.cos(phi);
  }
  const starGeo = new THREE.BufferGeometry();
  starGeo.setAttribute('position', new THREE.BufferAttribute(starPos, 3));
  scene.add(new THREE.Points(starGeo, new THREE.PointsMaterial({
    color: 0xffffff,
    size: 0.22,
    sizeAttenuation: true,
    transparent: true,
    opacity: 0.65,
  })));

  // ── Blue Fresnel glow around event horizon ──
  scene.add(new THREE.Mesh(
    new THREE.SphereGeometry(7.5, 32, 32),
    new THREE.ShaderMaterial({
      vertexShader: `
        varying vec3 vNormal;
        varying vec3 vViewDir;
        void main() {
          vNormal = normalize(normalMatrix * normal);
          vec4 mv = modelViewMatrix * vec4(position, 1.0);
          vViewDir = normalize(-mv.xyz);
          gl_Position = projectionMatrix * mv;
        }
      `,
      fragmentShader: `
        varying vec3 vNormal;
        varying vec3 vViewDir;
        void main() {
          float f = pow(1.0 - abs(dot(vNormal, vViewDir)), 2.8);
          gl_FragColor = vec4(0.15, 0.5, 1.0, f * 0.55);
        }
      `,
      transparent: true,
      side: THREE.BackSide,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
    })
  ));

  // ── Accretion disk ──
  const BH_R      = 5.5;
  const DISK_IN   = 6.3;
  const DISK_OUT  = 20.0;

  const diskMat = new THREE.ShaderMaterial({
    uniforms: {
      uTime:   { value: 0.0 },
      uCamDir: { value: new THREE.Vector3(0, 0, 1) },
      uBHR:    { value: BH_R },
    },
    vertexShader: `
      uniform vec3  uCamDir;
      uniform float uBHR;
      varying vec3  vWP;

      void main() {
        vec3 wp = (modelMatrix * vec4(position, 1.0)).xyz;
        vWP = wp;

        float r  = length(wp.xz);
        float fc = dot(normalize(wp.xz), uCamDir.xz);
        float bf = smoothstep(0.1, 0.9, max(0.0, -fc));
        float ls = pow(clamp(uBHR / max(r, uBHR + 0.01), 0.0, 1.0), 2.0);

        vec3 disp = wp + vec3(0.0, bf * ls * 10.0, 0.0);
        gl_Position = projectionMatrix * viewMatrix * vec4(disp, 1.0);
      }
    `,
    fragmentShader: `
      uniform float uTime;
      varying vec3  vWP;

      void main() {
        float r     = length(vWP.xz);
        float inner = 6.3;
        float outer = 20.0;
        float t     = clamp((r - inner) / (outer - inner), 0.0, 1.0);

        vec3 c0 = vec3(1.00, 0.98, 0.92);
        vec3 c1 = vec3(1.00, 0.67, 0.27);
        vec3 c2 = vec3(1.00, 0.27, 0.00);
        vec3 c3 = vec3(0.28, 0.05, 0.00);

        vec3 col;
        if      (t < 0.30) col = mix(c0, c1, t / 0.30);
        else if (t < 0.65) col = mix(c1, c2, (t - 0.30) / 0.35);
        else               col = mix(c2, c3, (t - 0.65) / 0.35);

        float ang  = atan(vWP.z, vWP.x);
        float turb = 0.12 * sin(ang * 7.0  + uTime * 0.9)
                   + 0.07 * sin(ang * 17.0 - uTime * 0.5)
                   + 0.05 * sin(ang * 29.0 + uTime * 1.3);
        col *= 1.0 + turb;

        float bri = mix(1.6, 0.25, t);
        float a   = smoothstep(0.0, 0.06, t) * (1.0 - smoothstep(0.76, 1.0, t));

        gl_FragColor = vec4(col * bri, a * 0.93);
      }
    `,
    transparent: true,
    side: THREE.DoubleSide,
    blending: THREE.AdditiveBlending,
    depthWrite: false,
    depthTest: true,
  });

  const accretionDisk = new THREE.Mesh(
    new THREE.RingGeometry(DISK_IN, DISK_OUT, 256, 64),
    diskMat
  );
  accretionDisk.rotation.x = -Math.PI / 2;
  accretionDisk.renderOrder = 0;
  scene.add(accretionDisk);

  // ── Event horizon ──
  const blackHole = new THREE.Mesh(
    new THREE.SphereGeometry(5, 64, 64),
    new THREE.MeshBasicMaterial({ color: 0x000000 })
  );
  blackHole.renderOrder = 1;
  scene.add(blackHole);

  // ── Animation ──
  let elapsed = 0;
  const camDir2D = new THREE.Vector2();

  function animate() {
    requestAnimationFrame(animate);
    elapsed += 0.006;

    camera.position.x = Math.sin(elapsed * 0.04) * 60;
    camera.position.z = Math.cos(elapsed * 0.04) * 60;
    camera.lookAt(0, 0, 0);

    camDir2D.set(camera.position.x, camera.position.z).normalize();
    diskMat.uniforms.uCamDir.value.set(camDir2D.x, 0, camDir2D.y);
    diskMat.uniforms.uTime.value = elapsed;

    accretionDisk.rotation.y += 0.0025;

    renderer.render(scene, camera);
  }
  animate();

  window.addEventListener('resize', () => {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
  });
})();
</script>
