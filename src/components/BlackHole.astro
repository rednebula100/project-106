---
---
<script is:inline>
(async function () {
  let THREE;
  try {
    THREE = await import('https://cdn.jsdelivr.net/npm/three@0.170.0/build/three.module.js');
  } catch (e) {
    console.error('[BH] THREE load failed:', e);
    return;
  }

  const canvas = document.createElement('canvas');
  canvas.id = 'bh-canvas';
  canvas.style.cssText = 'position:fixed;inset:0;width:100%;height:100%;z-index:0;pointer-events:none;display:block;';
  document.body.insertBefore(canvas, document.body.firstChild);

  const isMobile = window.innerWidth < 768;
  const dpr = isMobile ? 0.5 : Math.min(window.devicePixelRatio, 1.5);
  const renderer = new THREE.WebGLRenderer({ canvas, antialias: !isMobile, alpha: true });
  renderer.setPixelRatio(dpr);
  renderer.setSize(window.innerWidth, window.innerHeight);

  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(50, window.innerWidth / window.innerHeight, 0.1, 1000);
  camera.position.set(0, 21, 77);
  camera.lookAt(0, 0, 0);

  // ── Stars ──
  const STAR_COUNT = 1800;
  const starPos = new Float32Array(STAR_COUNT * 3);
  for (var i = 0; i < STAR_COUNT; i++) {
    var theta = Math.random() * Math.PI * 2;
    var phi   = Math.acos(2 * Math.random() - 1);
    var r     = 130 + Math.random() * 70;
    starPos[i * 3]     = r * Math.sin(phi) * Math.cos(theta);
    starPos[i * 3 + 1] = r * Math.sin(phi) * Math.sin(theta);
    starPos[i * 3 + 2] = r * Math.cos(phi);
  }
  var starGeo = new THREE.BufferGeometry();
  starGeo.setAttribute('position', new THREE.BufferAttribute(starPos, 3));
  scene.add(new THREE.Points(starGeo, new THREE.PointsMaterial({
    color: 0xffffff, size: 0.25, sizeAttenuation: true, transparent: true, opacity: 0.7,
  })));

  var BH_R = 7.5, DISK_IN = 9.5, DISK_OUT = 30.0;
  // Camera fixed at (0,21,77): xz direction from origin to camera = (0,0,1)
  var CAM_DIR = new THREE.Vector3(0, 0, 1);

  var diskVS = `
    uniform vec3 uCamDir;
    uniform float uBHR;
    varying vec3 vWP;
    void main() {
      vec3 wp = (modelMatrix * vec4(position, 1.0)).xyz;
      vWP = wp;
      float r  = length(wp.xz);
      float fc = dot(normalize(wp.xz), uCamDir.xz);
      float bf = smoothstep(0.1, 0.9, max(0.0, -fc));
      float ls = pow(clamp(uBHR / max(r, uBHR + 0.01), 0.0, 1.0), 2.5);
      vec3 disp = wp + vec3(0.0, bf * ls * 20.0, 0.0);
      gl_Position = projectionMatrix * viewMatrix * vec4(disp, 1.0);
    }
  `;

  var diskFS = `
    uniform float uTime;
    uniform float uAlpha;
    uniform vec3 uCamDir;
    varying vec3 vWP;
    void main() {
      float r = length(vWP.xz);
      float t = clamp((r - 9.5) / (30.0 - 9.5), 0.0, 1.0);

      vec3 c0 = vec3(1.00, 1.00, 1.00);
      vec3 c1 = vec3(1.00, 0.87, 0.53);
      vec3 c2 = vec3(1.00, 0.53, 0.00);
      vec3 c3 = vec3(1.00, 0.20, 0.00);
      vec3 c4 = vec3(0.25, 0.03, 0.00);
      vec3 col;
      if      (t < 0.18) col = mix(c0, c1, t / 0.18);
      else if (t < 0.38) col = mix(c1, c2, (t - 0.18) / 0.20);
      else if (t < 0.60) col = mix(c2, c3, (t - 0.38) / 0.22);
      else               col = mix(c3, c4, (t - 0.60) / 0.40);

      float ang = atan(vWP.z, vWP.x);
      col *= 1.0
        + 0.14 * sin(ang *  5.0 + uTime * 0.7)
        + 0.09 * sin(ang * 11.0 - uTime * 0.5)
        + 0.06 * sin(ang * 19.0 + uTime * 0.3)
        + 0.04 * sin(ang * 31.0 - uTime * 0.2);

      vec2 tangent = normalize(vec2(-vWP.z, vWP.x));
      col *= max(0.0, 1.0 + 0.45 * dot(tangent, uCamDir.xz));
      col *= 1.0 + 0.08 * sin(uTime * 3.7 + ang * 2.0) * (1.0 - t);

      float bri = mix(2.0, 0.20, t);
      float a   = smoothstep(0.0, 0.08, t) * (1.0 - smoothstep(0.72, 1.0, t));
      gl_FragColor = vec4(col * bri, a * uAlpha);
    }
  `;

  function makeDiskMat(alpha) {
    return new THREE.ShaderMaterial({
      uniforms: {
        uTime:   { value: 0.0 },
        uAlpha:  { value: alpha },
        uCamDir: { value: CAM_DIR.clone() },
        uBHR:    { value: BH_R },
      },
      vertexShader: diskVS,
      fragmentShader: diskFS,
      transparent: true, side: THREE.DoubleSide,
      blending: THREE.AdditiveBlending, depthWrite: false, depthTest: true,
    });
  }

  var diskGeom = new THREE.RingGeometry(DISK_IN, DISK_OUT, 256, 64);
  var allDiskMats = [];

  // Three disk layers: lower / main / upper — fixed, no rotation
  [[-0.8, 0.55], [0, 0.93], [0.8, 0.55]].forEach(function (pair) {
    var mat  = makeDiskMat(pair[1]);
    allDiskMats.push(mat);
    var mesh = new THREE.Mesh(diskGeom, mat);
    mesh.rotation.x = -Math.PI / 2;
    mesh.position.y = pair[0];
    mesh.renderOrder = 0;
    scene.add(mesh);
  });

  // ── Orange ambient glow ──
  scene.add(new THREE.Mesh(
    new THREE.SphereGeometry(28, 32, 32),
    new THREE.ShaderMaterial({
      vertexShader: `varying vec3 vN,vV; void main(){ vN=normalize(normalMatrix*normal); vec4 mv=modelViewMatrix*vec4(position,1.0); vV=normalize(-mv.xyz); gl_Position=projectionMatrix*mv; }`,
      fragmentShader: `varying vec3 vN,vV; void main(){ float f=pow(1.0-abs(dot(vN,vV)),3.5); gl_FragColor=vec4(1.0,0.45,0.05,f*0.18); }`,
      transparent: true, side: THREE.BackSide,
      blending: THREE.AdditiveBlending, depthWrite: false, depthTest: false,
    })
  ));

  // ── Rim light (event horizon boundary) ──
  var rimMesh = new THREE.Mesh(
    new THREE.SphereGeometry(BH_R * 1.12, 64, 64),
    new THREE.ShaderMaterial({
      vertexShader: `varying vec3 vN,vV; void main(){ vN=normalize(normalMatrix*normal); vec4 mv=modelViewMatrix*vec4(position,1.0); vV=normalize(-mv.xyz); gl_Position=projectionMatrix*mv; }`,
      fragmentShader: `varying vec3 vN,vV; void main(){ float f=pow(1.0-abs(dot(vN,vV)),1.8); vec3 col=mix(vec3(1.0,0.55,0.1),vec3(1.0,0.95,0.8),f); gl_FragColor=vec4(col,f*0.75); }`,
      transparent: true, side: THREE.FrontSide,
      blending: THREE.AdditiveBlending, depthWrite: false, depthTest: false,
    })
  );
  rimMesh.renderOrder = 3;
  scene.add(rimMesh);

  // ── Event horizon ──
  var blackHole = new THREE.Mesh(
    new THREE.SphereGeometry(BH_R, 64, 64),
    new THREE.MeshBasicMaterial({ color: 0x000000 })
  );
  blackHole.renderOrder = 2;
  scene.add(blackHole);

  // ── Animation (shader shimmer only — disk and camera are fixed) ──
  var elapsed = 0;
  function animate() {
    requestAnimationFrame(animate);
    elapsed += 0.006;
    for (var j = 0; j < allDiskMats.length; j++) {
      allDiskMats[j].uniforms.uTime.value = elapsed;
    }
    renderer.render(scene, camera);
  }
  animate();

  window.addEventListener('resize', function () {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
  });
})();
</script>
