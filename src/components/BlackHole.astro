---
const base = import.meta.env.BASE_URL;
---
<img
  id="bh-bg"
  src={`${base}images/Black_Hole_Full.png`}
  alt=""
  aria-hidden="true"
/>

<style>
  #bh-bg {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    object-fit: cover;
    object-position: center;
    opacity: 0.6;
    animation: bh-breathe 20s ease-in-out infinite;
  }

  @keyframes bh-breathe {
    0%   { transform: scale(1.00); }
    50%  { transform: scale(1.05); }
    100% { transform: scale(1.00); }
  }
</style>
