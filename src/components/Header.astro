---
---
<header class="header">
  <a href={import.meta.env.BASE_URL} class="header-logo">
    <span class="bracket">[</span>
    <span class="logo-text">PROJECT 106</span>
    <span class="bracket">]</span>
  </a>
  <nav class="header-nav">
    <a href={`${import.meta.env.BASE_URL}characters`}>캐릭터</a>
    <a href={`${import.meta.env.BASE_URL}organizations`}>조직</a>
    <a href={`${import.meta.env.BASE_URL}world`}>세계관</a>
    <a href={`${import.meta.env.BASE_URL}projects`}>프로젝트</a>
    <a href={`${import.meta.env.BASE_URL}timeline`}>연표</a>
    <a href={`${import.meta.env.BASE_URL}substances`}>초물질</a>
  </nav>
  <div class="header-status">
    <span class="status-dot"></span>
    <span>SYSTEM ONLINE</span>
  </div>
</header>

<style>
  .header {
    display: flex;
    align-items: center;
    padding: 0 1.5rem;
    height: 52px;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    gap: 2rem;
    flex-shrink: 0;
  }

  .header-logo {
    font-size: 1rem;
    letter-spacing: 0.15em;
    white-space: nowrap;
    color: var(--text-bright);
  }

  .header-logo:hover {
    text-decoration: none;
  }

  .bracket {
    color: var(--accent-blue);
  }

  .logo-text {
    margin: 0 0.3em;
  }

  .header-nav {
    display: flex;
    gap: 1.5rem;
    flex: 1;
  }

  .header-nav a {
    color: var(--text-dim);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.15s;
  }

  .header-nav a:hover {
    color: var(--text-bright);
    text-decoration: none;
  }

  .header-status {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.7rem;
    color: var(--text-dim);
    letter-spacing: 0.1em;
    white-space: nowrap;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #3aff6a;
    box-shadow: 0 0 5px #3aff6a;
  }
</style>
